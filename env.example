# ════════════════════════════════════════════════════
# ZEE BOT V2 - Environment Configuration
# Powered by CRYSNOVA AI V2 Technology
# ════════════════════════════════════════════════════
# Copy this file to .env and fill in your values


# ────────────────────────────────────────────────────
# BOT IDENTITY
# ────────────────────────────────────────────────────
BOT_NAME=ZEE BOT
OWNER_NUMBER=2347043550282
OWNER_NUMBERS=2347043550282
OWNER_NAME=ZEE OWNER
PREFIX=.

# ────────────────────────────────────────────────────
# SESSION
# ────────────────────────────────────────────────────
SESSION_NAME=sessions

# ────────────────────────────────────────────────────
# BOT MODE
# ────────────────────────────────────────────────────
# PUBLIC_MODE=true → anyone can use the bot
# PUBLIC_MODE=false → owner only
PUBLIC_MODE=true

# TERMINAL_MODE=true  → use pairing code (recommended)
# TERMINAL_MODE=false → scan QR code
TERMINAL_MODE=true

# Auto-react to commands with emojis
REACT_STATUS=true

# Always appear online
ALWAYS_ONLINE=true

# Auto-read messages
AUTO_READ=true

# Self bot (only respond to yourself)
SELF_BOT=false

# Auto typing indicator
AUTO_TYPING=false

# ────────────────────────────────────────────────────
# AUTO REPLY
# ────────────────────────────────────────────────────
AUTO_REPLY=true
AI_API_URL=https://all-in-1-ais.officialhectormanuel.workers.dev/
AI_MODEL=gpt-4.5-preview

# ────────────────────────────────────────────────────
# API KEYS (Optional — for AI/media features)
# ────────────────────────────────────────────────────
GROQ_API_KEY=
OPENAI_API_KEY=
WEATHER_API_KEY=
API_KEY=hector
API_BASEURL=https://hector-api.vercel.app/

# ────────────────────────────────────────────────────
# CUSTOMIZATION
# ────────────────────────────────────────────────────
# Custom thumbnail for connected message (must be direct image URL)
THUMB_URL=https://files.catbox.moe/z2rqc1.jpg

# Custom sticker author
STICKER_AUTHOR=ZEE BOT

# ────────────────────────────────────────────────────
# GROUP
# ────────────────────────────────────────────────────
GROUP_LINK=https://chat.whatsapp.com/Besbj8VIle1GwxKKZv1lax

# ────────────────────────────────────────────────────
# SERVER
# ────────────────────────────────────────────────────
PORT=3000

# ────────────────────────────────────────────────────
# LOGGING
# ────────────────────────────────────────────────────
# Levels: silent, error, warn, info, debug
LOG_LEVEL=silent

# ────────────────────────────────────────────────────
# SUDO USERS (comma-separated numbers, no +)
# Sudo users have near-owner access (can use admin commands)
# but NOT ownerOnly commands
# ────────────────────────────────────────────────────
SUDO_NUMBERS=

# ────────────────────────────────────────────────────
# AUTO STATUS
# ────────────────────────────────────────────────────
AUTO_STATUS_VIEW=true
AUTO_STATUS_LIKE=true
GROUP_AI=false

